--- a/arch/mips/include/uapi/asm/sysmips.h	2026-04-28 19:50:58.922927419 +0300
+++ b/arch/mips/include/uapi/asm/sysmips.h	2026-04-28 19:52:34.122944708 +0300
@@ -22,5 +22,6 @@
 #define MIPS_FIXADE		   7	/* control address error fixing	 */
 #define MIPS_RDNVRAM		  10	/* read NVRAM */
 #define MIPS_ATOMIC_SET		2001	/* atomically set variable	 */
