+++ b/libgcc/config/mips/t-r5900	2026-06-03 18:51:28.232873584 +0300
@@ -0,0 +1,15 @@
+LIB2FUNCS_EXCLUDE += _clrsbsi2 _clzsi2 _ctzsi2 _ffssi2
+
+LIB2ADD += $(srcdir)/config/mips/r5900/_clrsbsi2.S \
+           $(srcdir)/config/mips/r5900/_clzsi2.S \
+           $(srcdir)/config/mips/r5900/_ctzsi2.S \
+           $(srcdir)/config/mips/r5900/_ffssi2.S
+
+ifneq ($(filter -mabi=32,$(MULTILIB_CFLAGS) $(CFLAGS)),)
+LIB2FUNCS_EXCLUDE += _clrsbdi2 _clzdi2 _ctzdi2 _ffsdi2
+LIB2ADD += $(srcdir)/config/mips/r5900/_clrsbdi2.S \
+           $(srcdir)/config/mips/r5900/_clzdi2.S \
+           $(srcdir)/config/mips/r5900/_ctzdi2.S \
+           $(srcdir)/config/mips/r5900/_ffsdi2.S
