@@ -3142,7 +3142,24 @@
 ;;  ...................
 ;;
 
-(define_insn "clz<mode>2"
+(define_expand "clzsi2"
+  [(set (match_operand:SI 0 "register_operand")
+	(clz:SI (match_operand:SI 1 "register_operand")))]
+  "ISA_HAS_CLZ_CLO || TARGET_MIPS5900"
+  {
+    if (TARGET_MIPS5900)
+      {
+	rtx scratch = gen_rtx_SCRATCH (SImode);
+	
+	emit_insn (gen_rtx_PARALLEL (VOIDmode,
+	  gen_rtvec (2,
+	    gen_rtx_SET (operands[0], gen_rtx_CLZ (SImode, operands[1])),
+	    gen_rtx_CLOBBER (VOIDmode, scratch))));
+	DONE;
+      }
+  })
+
+(define_insn "*clz<mode>2"
   [(set (match_operand:GPR 0 "register_operand" "=d")
 	(clz:GPR (match_operand:GPR 1 "register_operand" "d")))]
   "ISA_HAS_CLZ_CLO"
@@ -3150,6 +3167,15 @@
   [(set_attr "type" "clz")
    (set_attr "mode" "<MODE>")])
 
+(define_insn "*clzsi2_r5900"
+  [(set (match_operand:SI 0 "register_operand" "=&d")
+	(clz:SI (match_operand:SI 1 "register_operand" "d")))
+   (clobber (match_scratch:SI 2 "=&d"))]
+  "TARGET_MIPS5900"
+  "srl\t%2,%1,31\;plzcw\t%0,%1\;addiu\t%0,%0,1\;movn\t%0,$zero,%2"
+  [(set_attr "type" "clz")
+   (set_attr "mode" "SI")])
+
 ;;
 ;;  ...................
 ;;
@@ -3158,7 +3184,24 @@
 ;;  ...................
 ;;
 
-(define_insn "ctz<mode>2"
+(define_expand "ctzsi2"
+  [(set (match_operand:SI 0 "register_operand")
+	(ctz:SI (match_operand:SI 1 "register_operand")))]
+  "ISA_HAS_CTZ_CTO || TARGET_MIPS5900"
+  {
+    if (TARGET_MIPS5900)
+      {
+	rtx scratch = gen_rtx_SCRATCH (SImode);
+	
+	emit_insn (gen_rtx_PARALLEL (VOIDmode,
+	  gen_rtvec (2,
+	    gen_rtx_SET (operands[0], gen_rtx_CTZ (SImode, operands[1])),
+	    gen_rtx_CLOBBER (VOIDmode, scratch))));
+	DONE;
+      }
+  })
+
+(define_insn "*ctz<mode>2"
   [(set (match_operand:GPR 0 "register_operand" "=d")
 	(ctz:GPR (match_operand:GPR 1 "register_operand" "d")))]
   "ISA_HAS_CTZ_CTO"
@@ -3166,6 +3209,14 @@
   [(set_attr "type" "clz")
    (set_attr "mode" "<MODE>")])
 
+(define_insn "*ctzsi2_r5900"
+  [(set (match_operand:SI 0 "register_operand" "=&d")
+	(ctz:SI (match_operand:SI 1 "register_operand" "d"))) ;; Вот здесь теперь СТРОГО ctz:SI!
+   (clobber (match_scratch:SI 2 "=&d"))]
+  "TARGET_MIPS5900"
+  "subu\t%2,$zero,%1\;and\t%2,%1,%2\;addiu\t%2,%2,-1\;sltiu\t%0,%1,1\;plzcw\t%2,%2\;sll\t%0,%0,31\;xori\t%2,%2,31\;sra\t%0,%0,31\;or\t%0,%0,%2"
