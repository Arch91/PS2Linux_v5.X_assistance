diff -Naur a/libgcc/config.host b/libgcc/config.host
--- a/libgcc/config.host	2019-01-17 15:29:13.000000000 +0300
+++ b/libgcc/config.host	2026-06-19 07:11:09.629749398 +0300
@@ -917,6 +917,8 @@
 	  mips64r5900* | mipsr5900*)
 	    # The MIPS16 support code uses floating point
 	    # instructions that are not supported on r5900.
+	    # Optimize libgcc functions with special instructions as long as they comply with the ABI.
+	    tmake_file="${tmake_file} mips/t-r5900"
 	    ;;
 	  *)
 	    tmake_file="${tmake_file} mips/t-mips16 t-slibgcc-libgcc"
